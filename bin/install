#!/usr/bin/env sh
set -eu

ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
PKGBUILD_DIR="$ROOT/pkgbuild"

if ! command -v makepkg >/dev/null 2>&1; then
  echo "makepkg is required to build and install the Arch package." >&2
  exit 1
fi

"$ROOT/bin/build"

cd "$PKGBUILD_DIR"
exec makepkg -fsi "$@"
