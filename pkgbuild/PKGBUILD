# Maintainer: David Heinemeier Hansson <david@hey.com>

pkgname=omawrite
pkgver=0.1.0
pkgrel=1
pkgdesc='Dead-simple Markdown writing app built with Qt Quick'
arch=('x86_64')
url='https://github.com/omacom-io/omawrite'
license=('MIT')
install='omawrite.install'
depends=('qt6-base' 'qt6-declarative' 'ttf-ia-writer' 'xdg-desktop-portal')
makedepends=('gcc' 'make' 'qt6-base' 'qt6-declarative')
source=()
sha256sums=()

build() {
  cd "$startdir/.."
  ./bin/build
}

package() {
  cd "$startdir/.."
  /usr/bin/install -Dm755 build/omawrite "$pkgdir/usr/bin/omawrite"
  /usr/bin/install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  /usr/bin/install -Dm644 "$startdir/omawrite.svg" "$pkgdir/usr/share/icons/hicolor/scalable/apps/omawrite.svg"
  /usr/bin/install -Dm644 "$startdir/omawrite.desktop" "$pkgdir/usr/share/applications/omawrite.desktop"
}
